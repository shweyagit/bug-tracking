# PostgreSQL
POSTGRES_USER=bta
POSTGRES_PASSWORD=bta_secret
POSTGRES_DB=bug_tracking
DATABASE_URL=postgresql+asyncpg://bta:bta_secret@postgres:5432/bug_tracking

# Redis
REDIS_URL=redis://redis:6379

# GitHub
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx
GITHUB_WEBHOOK_SECRET=your_random_secret_string
GITHUB_REPO=your-org/your-repo

# Jira
JIRA_PROJECT_KEY=SCRUM
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your_jira_api_token

# TestRail (optional)
TESTRAIL_BASE_URL=https://your-org.testrail.io/
TESTRAIL_EMAIL=your@email.com
TESTRAIL_API_KEY=your_testrail_api_key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# App
APP_ENV=development
LOG_LEVEL=INFO
PROJECT_NAME=YourProjectName

# URL of the app under test (for Playwright verification)
# Local: http://localhost:3000  |  Docker: http://host.docker.internal:3000
APP_URL=http://localhost:3000

# Verification service (runs on host machine, called from Docker)
VERIFY_SERVICE_URL=http://host.docker.internal:8502
